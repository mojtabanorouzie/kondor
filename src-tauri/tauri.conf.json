{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kondor",
  "version": "1.0.5",
  "identifier": "com.kondor.app",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Kondor",
        "width": 1100,
        "height": 760,
        "minWidth": 480,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
