# Kondor Sync Server — environment variables
# Copy this file to .env and fill in your values.

# Port the server listens on (default: 3000)
PORT=3000

# Path to the SQLite database file (default: kondor-server.db)
DB_PATH=kondor-server.db

# JWT signing secret — MUST be set to a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-in-production

# Google OAuth credentials (optional — leave blank to disable Google login)
# Create at https://console.developers.google.com/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth credentials (optional — leave blank to disable GitHub login)
# Create at https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
